{
  "name": "pyfix-pos",
  "version": "1.0.0",
  "description": "PYFIX POS — Sistema de punto de venta para minimarkets",
  "main": "main.js",
  "author": {
    "name": "Fixio SAS",
    "email": "hola@soyfixio.com"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron": "^28"
  },
  "devDependencies": {
    "electron-builder": "^24"
  },
  "build": {
    "appId": "com.soyfixio.pyfix-pos",
    "productName": "PYFIX POS",
    "copyright": "Copyright © 2026 Fixio SAS",
    "directories": {
      "output": "../dist-installer"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend",
        "filter": ["**/*"]
      },
      {
        "from": "../backend-dist/backend.exe",
        "to": "backend/backend.exe"
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PYFIX POS",
      "installerFileName": "PYFIX-POS-Setup.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "magojhonblackia",
      "repo": "pyfix-pos"
    }
  }
}
