# ── Base de datos ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./pyfix_local.db

# ── JWT ───────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-segura-en-produccion
ACCESS_TOKEN_EXPIRE_HOURS=8

# ── CORS (separados por coma, sin espacios) ───────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Servidor ──────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8765

# ── Hardware ──────────────────────────────────────────────────
# true  → modo simulado (sin hardware físico)
# false → hardware real (balanza RS-232, impresora ESC/POS)
HARDWARE_MOCK=true
